# Twenty CRM — homelab deploy env (CT 214 / crm.alpina.solutions)
# Copy to .env, fill real values, never commit .env.
# Vendored compose: infra/homelab/docker-compose.yml (from packages/twenty-docker).

# Pin to a released tag in production (not "latest"). e.g. TAG=v0.40.0
TAG=latest

# Postgres (bundled db service). No special characters in the password.
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=replace_me_strong_no_special_chars
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432

# Redis (bundled)
REDIS_URL=redis://redis:6379

# Public URL (CF tunnel terminates TLS; container speaks http on :3000)
SERVER_URL=https://crm.alpina.solutions

# Secrets — generate each with: openssl rand -base64 32
ENCRYPTION_KEY=replace_me_random
# FALLBACK_ENCRYPTION_KEY=  # set to the previous ENCRYPTION_KEY only during a rotation

# Local file storage (volume server-local-data); switch to S3/MinIO later if desired
STORAGE_TYPE=local

# Notes:
# - Signup gating is a workspace setting in the Twenty admin UI (no env flag in this
#   version). After creating the first workspace, disable public sign-up there.
# - For agent access, create an API key in Settings -> Developers; it is stored on PVE
#   at /root/.homelab-creds/twenty.txt and consumed by twenty-mcp.
